# Copy this file to AppStore/submission.env and fill in your real App Store values.
# AppStore/submission.env is ignored by git.

# Apple Developer / App Store Connect identifiers
TASKISLAND_BUNDLE_ID="com.yuxiao.TaskIsland"
TASKISLAND_APPSTORE_SKU="taskisland-mac-001"

# App Store versioning is separate from the GitHub / feature VERSION file.
TASKISLAND_APPSTORE_VERSION="0.1.7"
TASKISLAND_APPSTORE_BUILD="1"

# Mac App Store package target. Keep universal unless you intentionally drop Intel Macs.
TASKISLAND_MIN_MACOS="15.0"
TASKISLAND_APPSTORE_ARCHS="arm64 x86_64"

# Signing certificates installed in Keychain.
TASKISLAND_APPSTORE_APP_SIGN_IDENTITY="3rd Party Mac Developer Application: Xiao Yu (9PZ46S64H2)"
TASKISLAND_APPSTORE_INSTALLER_SIGN_IDENTITY="3rd Party Mac Developer Installer: Xiao Yu (9PZ46S64H2)"

# App Store provisioning profile exported/downloaded from Apple Developer.
# Leave empty until you have the profile file, then use an absolute path.
TASKISLAND_APPSTORE_PROVISIONING_PROFILE=""

# App Store Connect metadata links.
TASKISLAND_PRIVACY_URL="https://example.com/privacy"
TASKISLAND_SUPPORT_URL="https://example.com/support"

# App Store Connect page choices. These are for your records/checklist.
TASKISLAND_APPSTORE_APP_NAME="任务岛"
TASKISLAND_APPSTORE_PRIMARY_LOCALE="zh-Hans"
TASKISLAND_APPSTORE_REGIONS="Worldwide except China Mainland until ICP/App filing is approved"
TASKISLAND_APPSTORE_CATEGORY="Productivity"
TASKISLAND_APPSTORE_PRICE="Paid one-time purchase, tier TBD"
